---
import "@fontsource-variable/inter";
import logo from "../assets/logo.svg";

const repo = "https://github.com/inquisoai/inquiso";
const org = "https://github.com/inquisoai";

const does = [
  ["Ask", "Grounded answers with the page as context — no copy-pasting into another tab."],
  ["Summarize", "The key points of a long article, a document, or a whole window of tabs."],
  ["Assess", "Whether a source is trustworthy, and what its bias is, before you rely on it."],
  ["Act", "Fill a form, compare options, complete a task — sensitive actions need your confirmation."],
];

const principles = [
  ["Bring your own model", "Free and local with Chrome Built-in AI, or your own key for OpenAI, Anthropic, Google, Qwen, or Kimi."],
  ["Transparent", "Every reasoning step and action is shown. Nothing irreversible happens without your confirmation."],
  ["Local-first & serverless", "No Inquiso backend, no telemetry, no sync. Data goes only to the provider you choose."],
  ["Private by design", "Manifest V3, a locked-down CSP, encrypted keys, and first-class prompt-injection defenses."],
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Inquiso — Chat with any web page</title>
    <meta name="description" content="An open-source AI sidebar and transparent agent for your browser. Ask, summarize, assess, and act on any page — with your own model, entirely on your machine." />
    <meta property="og:title" content="Inquiso — Chat with any web page" />
    <meta property="og:description" content="Open-source, local-first AI sidebar and agent for the web. Bring your own model." />
    <meta property="og:url" content="https://inquisoai.com" />
  </head>
  <body>
    <div class="wrap">
      <header>
        <a class="brand" href="/">
          <img src={logo.src} alt="" width="24" height="24" />
          Inquiso
        </a>
        <nav>
          <a href="/docs/">Docs</a>
          <a href={repo}>GitHub</a>
        </nav>
      </header>

      <main>
        <section class="hero">
          <p class="eyebrow">Open-source browser extension</p>
          <h1>Chat with any web page.</h1>
          <p class="lead">
            Inquiso is an AI sidebar and transparent agent for your browser. It reads the page
            you're on — or a whole tab group, or a window — and answers, summarizes, checks
            trustworthiness, and takes actions. Local-first, serverless, and it uses your own model.
          </p>
          <div class="actions">
            <a class="button" href={repo}>Get the extension</a>
            <a class="textlink" href="/docs/">Documentation &rarr;</a>
          </div>
          <p class="note">Chrome · Firefox · Chromium — no account, no telemetry.</p>
        </section>

        <section class="spec">
          <h2>What it does</h2>
          <dl>
            {does.map(([t, d]) => (
              <div class="rowitem">
                <dt>{t}</dt>
                <dd>{d}</dd>
              </div>
            ))}
          </dl>
        </section>

        <section class="spec">
          <h2>Principles</h2>
          <dl>
            {principles.map(([t, d]) => (
              <div class="rowitem">
                <dt>{t}</dt>
                <dd>{d}</dd>
              </div>
            ))}
          </dl>
        </section>

        <section class="closing">
          <p>Free on-device AI or your own key — you're always in control.</p>
          <div class="actions">
            <a class="button" href={repo}>Get the extension</a>
            <a class="textlink" href="/docs/10-user-guide">Read the user guide &rarr;</a>
          </div>
        </section>
      </main>

      <footer>
        <nav>
          <a href="/docs/">Docs</a>
          <a href={repo}>GitHub</a>
          <a href={`${org}/.github/blob/main/GOVERNANCE.md`}>Governance</a>
          <a href={`${org}/.github/blob/main/CONTRIBUTING.md`}>Contributing</a>
          <a href={`${repo}/security/advisories/new`}>Security</a>
        </nav>
        <p>© 2026 Inquiso · <a href={`${repo}/blob/main/LICENSE`}>MIT</a></p>
      </footer>
    </div>

    <style is:global>
      :root {
        --bg: #ffffff;
        --text: #1c1c1e;
        --muted: #6b6b70;
        --line: #e7e7e9;
        --link: #1c1c1e;
      }
      @media (prefers-color-scheme: dark) {
        :root { --bg: #0e0e10; --text: #ececee; --muted: #9a9aa0; --line: #26262a; --link: #ececee; }
        .brand img { box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.14); }
      }
      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        font-family: "Inter Variable", system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.65;
        font-size: 17px;
        -webkit-font-smoothing: antialiased;
      }
      .wrap { max-width: none; margin: 0; padding: 0 clamp(24px, 5vw, 80px); }
      main { counter-reset: spec; }
      a { color: inherit; text-decoration: none; }
      ::selection { background: var(--text); color: var(--bg); }
      :focus-visible { outline: 2px solid var(--text); outline-offset: 3px; border-radius: 3px; }

      header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 28px 0; margin-bottom: 40px;
      }
      .brand { display: inline-flex; align-items: center; gap: 9px; font-weight: 600; font-size: 16px; }
      .brand img { border-radius: 6px; }
      header nav { display: flex; gap: 22px; font-size: 15px; color: var(--muted); }
      header nav a:hover { color: var(--text); }

      .eyebrow {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 13px; letter-spacing: 0.02em; color: var(--muted);
        margin: 0 0 18px; text-transform: none;
      }
      h1 {
        font-size: clamp(40px, 6.5vw, 68px); font-weight: 600; letter-spacing: -0.025em;
        line-height: 1.05; margin: 0;
      }
      .lead { color: var(--muted); font-size: 20px; margin: 24px 0 0; max-width: 640px; }

      .actions { display: flex; align-items: center; gap: 20px; margin-top: 30px; flex-wrap: wrap; }
      .button {
        display: inline-flex; align-items: center; padding: 10px 18px; border-radius: 8px;
        background: var(--text); color: var(--bg); font-weight: 500; font-size: 15px;
        transition: opacity .15s ease;
      }
      .button:hover { opacity: 0.85; }
      .textlink { color: var(--muted); font-size: 15px; }
      .textlink:hover { color: var(--text); }
      .note { color: var(--muted); font-size: 14px; margin: 18px 0 0; }

      section { padding: 72px 0; }
      section + section { border-top: 1px solid var(--line); }
      .hero { padding-top: 12px; padding-bottom: 72px; border-bottom: 1px solid var(--line); }

      .spec { display: grid; grid-template-columns: 200px 1fr; gap: 32px 56px; align-items: start; }
      h2 {
        font-size: 13px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
        color: var(--muted); margin: 0; padding-top: 4px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      .spec h2::before {
        counter-increment: spec;
        content: counter(spec, decimal-leading-zero);
        display: block; margin-bottom: 12px; letter-spacing: 0;
        color: var(--text); opacity: 0.28; font-size: 13px;
      }
      dl { margin: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 40px 56px; }
      .rowitem { display: block; }
      dt { font-weight: 600; font-size: 18px; letter-spacing: -0.01em; margin-bottom: 7px; }
      dd { margin: 0; color: var(--muted); font-size: 16px; }
      @media (max-width: 820px) {
        .spec { grid-template-columns: 1fr; gap: 24px; }
        dl { gap: 28px 40px; }
      }
      @media (max-width: 540px) { dl { grid-template-columns: 1fr; } }

      .closing p { font-size: 19px; margin: 0; }

      footer {
        border-top: 1px solid var(--line); padding: 32px 0 56px;
        display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;
      }
      footer nav { display: flex; gap: 18px; flex-wrap: wrap; font-size: 14px; color: var(--muted); }
      footer nav a:hover { color: var(--text); }
      footer p { font-size: 14px; color: var(--muted); margin: 0; }
      footer p a { text-decoration: underline; text-underline-offset: 2px; }
    </style>
  </body>
</html>
